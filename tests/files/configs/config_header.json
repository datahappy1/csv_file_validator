{
  "file_metadata": {
    "file_value_separator": ",",
    "file_row_terminator": "\n",
    "file_has_header": true
  },
  "file_validation_rules": {
    "file_name_file_mask": "SalesJ",
    "file_extension": "csv",
    "file_header_column_names": [
      "Transaction_date",
      "Product",
      "Price",
      "Payment_Type",
      "Name",
      "City",
      "State",
      "Country",
      "Account_Created",
      "Last_Login",
      "Latitude",
      "Longitude"
    ],
    "file_size_range": [
      0,
      1
    ],
    "file_row_count_range": [
      0,
      1000
    ]
  },
  "column_validation_rules": {
    "Transaction_date": {
      "allow_data_type": "datetime"
    },
    "Country": {
      "allow_data_type": "str"
    },
    "Price": {
      "allow_numeric_value_range": [
        1000,
        100000
      ],
      "allow_data_type": "int"
    }
  }
}
